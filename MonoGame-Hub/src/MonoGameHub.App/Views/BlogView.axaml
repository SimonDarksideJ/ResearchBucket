<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:MonoGameHub.App.Controls"
             x:Class="MonoGameHub.App.Views.BlogView"
             mc:Ignorable="d">

  <DockPanel Margin="12">

    <controls:CollapsibleLogPanel DockPanel.Dock="Bottom" ItemsSource="{Binding LogLines}" Title="Logs" />

    <Grid RowDefinitions="Auto,Auto,*">

    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
      <Button Content="Refresh" Command="{Binding RefreshCommand}" />
      <TextBox Width="320" Watermark="Search" Text="{Binding Search, Mode=TwoWay}" />
    </StackPanel>

    <Border Grid.Row="1" Padding="0,8,0,8">
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding TagFilters}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <RadioButton Content="{Binding Name}"
                           IsChecked="{Binding IsSelected, Mode=TwoWay}"
                           GroupName="BlogTags"
                           Margin="0,0,8,0" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <Border Grid.Row="2" Classes="Card" BorderThickness="1" CornerRadius="6" Padding="6">
      <ScrollViewer>
        <ItemsControl ItemsSource="{Binding Items}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Button Width="320" Height="360" Margin="6" Padding="0"
                      Command="{Binding DataContext.OpenPostCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      CommandParameter="{Binding Url}">
                <Border Classes="Card" CornerRadius="6" BorderThickness="1">
                  <Grid RowDefinitions="140,*">
                    <Border Grid.Row="0" CornerRadius="6,6,0,0" ClipToBounds="True">
                      <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                    </Border>
                    <Border Grid.Row="1" Padding="10">
                      <StackPanel Spacing="6">
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxLines="2" />
                        <TextBlock Text="{Binding Author}" Opacity="0.75" FontSize="12" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding PublishedDate}" Opacity="0.75" FontSize="12" />
                        <TextBlock Text="{Binding Excerpt}" Opacity="0.9" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxLines="3" />
                        <TextBlock Text="{Binding TagsSummary}" Opacity="0.75" FontSize="12" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                      </StackPanel>
                    </Border>
                  </Grid>
                </Border>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    </Grid>

  </DockPanel>
</UserControl>
