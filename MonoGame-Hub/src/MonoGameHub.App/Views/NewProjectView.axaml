<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:MonoGameHub.App.Controls"
             x:Class="MonoGameHub.App.Views.NewProjectView"
             mc:Ignorable="d">

  <DockPanel Margin="12">

    <controls:CollapsibleLogPanel DockPanel.Dock="Bottom" ItemsSource="{Binding LogLines}" Title="Logs"
                   IsExpanded="{Binding IsLogExpanded, Mode=TwoWay}" />

    <Grid RowDefinitions="15*,70*,15*">

      <!-- Header (15%) -->
      <Grid Grid.Row="0" RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">
        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
          <TextBlock Width="110" VerticalAlignment="Center" Text="Project name" />
          <TextBox Width="340"
                   Watermark="MyMonoGameGame"
                   Text="{Binding ProjectName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   Background="{Binding ProjectFolderAlreadyExists, Converter={StaticResource ExistingProjectWarningBackgroundConverter}}"
                   BorderBrush="{Binding ProjectFolderAlreadyExists, Converter={StaticResource ExistingProjectWarningForegroundConverter}}" />
        </StackPanel>

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="110,0,0,8" Opacity="0.8"
                   IsVisible="{Binding ProjectFolderAlreadyExists}"
                   Foreground="{Binding ProjectFolderAlreadyExists, Converter={StaticResource ExistingProjectWarningForegroundConverter}}"
                   Text="A project already exists with this name" />

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="110,0,0,8" Opacity="0.9"
             IsVisible="{Binding SelectedTemplateMissingWorkload}"
             Foreground="{Binding SelectedTemplateMissingWorkload, Converter={StaticResource ExistingProjectWarningForegroundConverter}}"
             Text="{Binding SelectedTemplateMissingWorkloadText}" />

        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" Margin="0,0,0,8" MinHeight="56" VerticalAlignment="Center">
          <controls:ToolingStatusView DataContext="{Binding ToolingStatus}" />

          <Button Content="Create project" Command="{Binding CreateProjectCommand}" Click="OnCreateProjectClicked" VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8">
          <TextBlock Width="110" VerticalAlignment="Center" Text="Template" />
          <Button Content="Refresh" Command="{Binding RefreshTemplatesCommand}" />
        </StackPanel>
      </Grid>

      <!-- List (70%) -->
      <Border Grid.Row="1" Classes="Card" BorderThickness="1" Padding="6" CornerRadius="6">
        <Grid RowDefinitions="Auto,Auto,*">
          <Grid Grid.Row="0" Margin="2,0,2,6">
            <TextBlock Text="Templates" FontWeight="SemiBold" />
          </Grid>

          <Grid Grid.Row="1" ColumnDefinitions="*,320,160,140" Margin="2,0,2,6">
            <TextBlock Text="Template Name" FontWeight="Bold" />
            <TextBlock Grid.Column="1" Text="Template ID" FontWeight="Bold" Margin="12,0,0,0" MaxWidth="320" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" HorizontalAlignment="Right" />
            <TextBlock Grid.Column="2" Text="Workload" FontWeight="Bold" Margin="12,0,0,0" MaxWidth="160" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" HorizontalAlignment="Right" />
            <TextBlock Grid.Column="3" Text="Version" FontWeight="Bold" Margin="12,0,0,0" MaxWidth="140" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" HorizontalAlignment="Right" />
          </Grid>

          <Grid Grid.Row="2">
            <ListBox ItemsSource="{Binding TemplateOptions}"
                    SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel HorizontalAlignment="Stretch" />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
              <ListBox.Styles>
                <Style Selector="ListBoxItem">
                  <Setter Property="HorizontalAlignment" Value="Stretch" />
                  <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
              </ListBox.Styles>
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,320,160,140" Margin="2" HorizontalAlignment="Stretch">
                    <TextBlock Grid.Row="0" Grid.ColumnSpan="4" Text="{Binding Name}" TextWrapping="Wrap" TextTrimming="None"
                               Foreground="{Binding IsRequiredWorkloadMissing, Converter={StaticResource ExistingProjectWarningForegroundConverter}}" />

                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TemplateId}" Opacity="0.8" Margin="12,2,0,0" MaxWidth="320" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" HorizontalAlignment="Right"
                               Foreground="{Binding IsRequiredWorkloadMissing, Converter={StaticResource ExistingProjectWarningForegroundConverter}}" />

                    <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Vertical" Spacing="0" Margin="12,2,0,0" HorizontalAlignment="Right">
                      <TextBlock Text="{Binding RequiredWorkloadDisplay}" Opacity="0.8" MaxWidth="160" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                 Foreground="{Binding IsRequiredWorkloadMissing, Converter={StaticResource ExistingProjectWarningForegroundConverter}}" />
                      <TextBlock Text="workload not installed" FontWeight="Bold"
                                 IsVisible="{Binding IsRequiredWorkloadMissing}"
                                 Foreground="{Binding IsRequiredWorkloadMissing, Converter={StaticResource ExistingProjectWarningForegroundConverter}}" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding Version}" Opacity="0.8" Margin="12,2,0,0" MaxWidth="140" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" HorizontalAlignment="Right"
                               Foreground="{Binding IsRequiredWorkloadMissing, Converter={StaticResource ExistingProjectWarningForegroundConverter}}" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Text="Loading templates..."
                       Opacity="0.8"
                       IsHitTestVisible="False"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsTemplatesLoading}" />
          </Grid>
        </Grid>
      </Border>

      <!-- Footer (15%) -->
      <Grid Grid.Row="2" RowDefinitions="Auto,Auto,Auto">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
          <TextBlock Width="110" VerticalAlignment="Center" Text="Output root" />
          <Grid ColumnDefinitions="Auto,Auto">
            <TextBox Grid.Column="0" Width="600" Text="{Binding OutputRoot, Mode=TwoWay}" />
            <Button Grid.Column="1" Width="36" Content="..." Click="OnBrowseOutputRootClicked" />
          </Grid>
        </StackPanel>

        <TextBlock Grid.Row="1" Margin="110,0,0,8" Opacity="0.9"
                   IsVisible="{Binding ProjectsRootMissingWarning}"
                   Foreground="{Binding ProjectsRootMissingWarning, Converter={StaticResource ExistingProjectWarningForegroundConverter}}"
                   Text="Projects folder is not set. Choose an output root to continue." />

        <TextBlock Grid.Row="2" Opacity="0.7" Text="Templates are loaded from your installed dotnet template packages (MonoGame filtered by default)." />
      </Grid>

    </Grid>

  </DockPanel>
</UserControl>
